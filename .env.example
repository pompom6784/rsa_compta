APP_NAME="RSANav Compta"
APP_ENV=local
# APP_KEY is generated by "php artisan key:generate --show" and should be kept secret in production
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_DATABASE is used by Laravel's Eloquent. Doctrine selects the year-specific
# SQLite file via YearService + cache by scanning var/db_YYYY.sqlite (see config/doctrine.php)
DB_DATABASE=

SESSION_DRIVER=file
QUEUE_CONNECTION=sync
CACHE_STORE=file
