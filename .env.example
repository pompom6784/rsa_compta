APP_NAME="RSANav Compta"
APP_ENV=local
# APP_KEY is generated by "php artisan key:generate --show" and should be kept secret in production
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_DATABASE is used by Laravel's Eloquent; Doctrine uses the year-selected
# SQLite file from /var/current_year.txt (see config/doctrine.php)
DB_DATABASE=

SESSION_DRIVER=file
QUEUE_CONNECTION=sync
CACHE_STORE=file
